# Containerfile — Sealed bootc host with composefs root
#
# Builds a CentOS Stream 10 bootc image that boots with the composefs
# backend. A signed Unified Kernel Image (UKI) embeds the composefs
# digest; Secure Boot verifies the UKI, which in turn verifies every
# file on the root filesystem via fs-verity.
#
# Both the db private key and the db certificate are passed as build
# secrets.  The cert is public, but using a secret mount avoids
# SELinux label mismatches on bind-mounted host files and keeps the
# cert out of any image layer.
#
# Build:
#   podman build \
#     --secret id=secureboot_key,src=target/keys/sb-db.key \
#     --secret id=secureboot_cert,src=keys/db.crt \
#     -t localhost/sealed-host:latest .

# --- Stage: rootfs-builder (install packages on the bootc base) ---
FROM quay.io/centos-bootc/centos-bootc:stream10 AS rootfs-builder

# sbsigntools from EPEL; systemd-boot-unsigned for bootctl install
RUN --mount=type=tmpfs,target=/run --mount=type=tmpfs,target=/tmp \
    dnf -y install epel-release && \
    dnf -y install systemd-boot-unsigned systemd-ukify sbsigntools && \
    dnf clean all

# composefs backend uses systemd-boot, not grub/bootupd
RUN --mount=type=tmpfs,target=/run --mount=type=tmpfs,target=/tmp \
    rpm -e bootupd 2>/dev/null || true

# Default to ext4 (supports fsverity, required for composefs)
RUN --mount=type=tmpfs,target=/run --mount=type=tmpfs,target=/tmp \
    mkdir -p /usr/lib/bootc/install && \
    cat > /usr/lib/bootc/install/00-composefs.toml <<'EOF'
[install.filesystem.root]
type = "ext4"
EOF

# Sign systemd-boot with our Secure Boot key so UEFI firmware will load it.
# This must happen BEFORE the flatten so the signed binary is in the digest.
# Build secrets do not invalidate container build cache, so include a public
# certificate hash as an ARG to force re-signing when the signing key changes.
ARG secureboot_cert_sha=
RUN --mount=type=tmpfs,target=/run --mount=type=tmpfs,target=/tmp \
    --mount=type=secret,id=secureboot_key \
    --mount=type=secret,id=secureboot_cert \
    echo "Secure Boot cert sha: ${secureboot_cert_sha}" && \
    sbsign --key /run/secrets/secureboot_key \
           --cert /run/secrets/secureboot_cert \
           --output /tmp/systemd-bootx64.efi.signed \
           /usr/lib/systemd/boot/efi/systemd-bootx64.efi && \
    mv /tmp/systemd-bootx64.efi.signed /usr/lib/systemd/boot/efi/systemd-bootx64.efi

# --- Stage: base (flatten to single layer for deterministic digests) ---
FROM scratch AS base
COPY --from=rootfs-builder / /
LABEL containers.bootc=1
LABEL ostree.bootable=1
ENV container=oci
STOPSIGNAL SIGRTMIN+3
CMD ["/sbin/init"]

# --- Stage: final-rootfs (the exact rootfs that the UKI seals) ---
#
# The composefs digest embedded in the UKI must be computed from the same
# rootfs that bootc will install.  If this image is derived from a previous UKI
# image, remove any existing UKIs before computing the new digest; bootc
# container ukify intentionally refuses to seal a rootfs that already contains
# one.
FROM base AS final-rootfs
RUN --mount=type=tmpfs,target=/run --mount=type=tmpfs,target=/tmp \
    rm -rf /boot/EFI/Linux/*.efi

# --- Stage: kernel (build signed UKI) ---
#
# When composefs_digest is provided, it must be the install-time composefs
# digest computed from container storage for the final-rootfs image.  That is
# the digest bootc validates during install.  If omitted, fall back to bootc
# container ukify's mounted-rootfs digest, which is useful for debugging but can
# differ from the install-time OCI/storage view.
FROM final-rootfs AS kernel
ARG composefs_digest=
ARG secureboot_cert_sha=
RUN --mount=type=tmpfs,target=/run --mount=type=tmpfs,target=/tmp \
    --mount=type=bind,from=final-rootfs,target=/target \
    --mount=type=secret,id=secureboot_key \
    --mount=type=secret,id=secureboot_cert <<EORUN
set -xeuo pipefail
echo "Secure Boot cert sha: ${secureboot_cert_sha}"
mkdir -p /out
if [ -n "${composefs_digest}" ]; then
  kver=$(bootc container inspect --rootfs /target --json | jq -r '.kernel.version')
  ukify build \
    --linux "/target/usr/lib/modules/${kver}/vmlinuz" \
    --initrd "/target/usr/lib/modules/${kver}/initramfs.img" \
    --uname "${kver}" \
    --cmdline "composefs=${composefs_digest} rw console=hvc0,115200 systemd.journald.forward_to_console=1" \
    --os-release "@/target/usr/lib/os-release" \
    --signtool sbsign \
    --secureboot-private-key /run/secrets/secureboot_key \
    --secureboot-certificate /run/secrets/secureboot_cert \
    --output /out/uki.efi
else
  bootc container ukify --rootfs /target \
    --karg rw \
    --karg console=hvc0,115200 \
    --karg systemd.journald.forward_to_console=1 \
    -- \
    --signtool sbsign \
    --secureboot-private-key /run/secrets/secureboot_key \
    --secureboot-certificate /run/secrets/secureboot_cert \
    --output /out/uki.efi
fi
ls -lh /out/
EORUN

# --- Final image: final-rootfs + sealed UKI in /boot ---
# /boot is outside the composefs-verified root, so installing the UKI here after
# computing the digest does not change the composefs= value that bootc expects.
# Use a bind mount rather than COPY-to-/tmp plus mv so the final layer only adds
# the /boot artifact; it does not create and whiteout a temporary rootfs file.
FROM final-rootfs
RUN --mount=type=tmpfs,target=/run --mount=type=tmpfs,target=/tmp \
    --mount=type=bind,from=kernel,src=/out,target=/run/sealed-uki \
    kver=$(bootc container inspect --json | jq -r '.kernel.version') && \
    mkdir -p /boot/EFI/Linux && \
    cp /run/sealed-uki/uki.efi "/boot/EFI/Linux/${kver}.efi"
