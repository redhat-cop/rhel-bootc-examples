# Justfile for sealed composefs UKI boot
#
# Builds a CentOS Stream 10 bootc host that boots with the composefs
# backend (UKI + composefs digest + Secure Boot).
#
# Prerequisites: podman, openssl, just
# For VM testing: bcvk (from bootc-dev/bcvk), virt-firmware (pip)

# Local image name
host_image := "localhost/sealed-host:latest"
rootfs_image := "localhost/sealed-host:rootfs"

# Key material directory (for local dev; CI uses secrets)
keys_dir := justfile_directory() + "/target/keys"

# Generate Secure Boot keys (PK/KEK for enrollment, db for signing).
# Copies db.crt into keys/ for committing to the repo.
keygen:
    #!/bin/bash
    set -euo pipefail
    python3 util/keys.py generate --output-dir "{{keys_dir}}"
    mkdir -p keys/
    cp "{{keys_dir}}/sb-db.crt" keys/db.crt
    echo "keys/db.crt updated — commit it to the repo"

# Build the sealed host image (composefs backend with signed UKI).
# If no persistent key exists under target/keys/, an ephemeral key+cert pair
# is generated automatically (suitable for CI and local smoke-testing).
build:
    #!/bin/bash
    set -euo pipefail
    KEY="{{keys_dir}}/sb-db.key"
    CERT="{{keys_dir}}/sb-db.crt"

    if [ ! -f "${KEY}" ] || [ ! -f "${CERT}" ] || [ ! -f "{{keys_dir}}/PK.crt" ] || [ ! -f "{{keys_dir}}/KEK.crt" ]; then
        echo "No complete Secure Boot key set found — generating one."
        python3 util/keys.py generate --output-dir "{{keys_dir}}"
    fi

    # Keep the public db certificate in the repo in sync with the private key
    # used for signing.  bcvk enrolls {{keys_dir}}/db.crt into OVMF, so signing
    # with a stale keys/db.crt can produce binaries rejected by Secure Boot.
    mkdir -p keys/
    cp "${CERT}" keys/db.crt
    SECUREBOOT_CERT_SHA=$(sha256sum "${CERT}" | awk '{print $1}')

    echo "==> Building rootfs image used for install-time composefs digest..."
    podman build \
        --target final-rootfs \
        --build-arg secureboot_cert_sha="${SECUREBOOT_CERT_SHA}" \
        --secret id=secureboot_key,src="${KEY}" \
        --secret id=secureboot_cert,src="${CERT}" \
        -t "{{rootfs_image}}" .

    echo "==> Computing install-time composefs digest from container storage..."
    GRAPHROOT=$(podman system info --format json | jq -r '.store.graphRoot')
    # With no image argument, bootc uses the running container's image ID and
    # looks it up through /run/host-container-storage.  This matches bootc's
    # own validation helper and avoids tag/raw-ID parsing issues.
    COMPOSEFS_DIGEST=$(podman run --rm --privileged \
        --security-opt=label=disable \
        -v "${GRAPHROOT}:/run/host-container-storage:ro" \
        --tmpfs=/var \
        "{{rootfs_image}}" \
        bootc container compute-composefs-digest-from-storage | tail -n1)
    echo "composefs digest: ${COMPOSEFS_DIGEST}"

    echo "==> Building final sealed image..."
    podman build \
        --build-arg composefs_digest="${COMPOSEFS_DIGEST}" \
        --build-arg secureboot_cert_sha="${SECUREBOOT_CERT_SHA}" \
        --secret id=secureboot_key,src="${KEY}" \
        --secret id=secureboot_cert,src="${CERT}" \
        -t "{{host_image}}" .
    echo "Host image built: {{host_image}}"

# Internal: boot the VM (used by bcvk-ssh and bcvk-test).
[private]
bcvk-boot: build
    #!/bin/bash
    set -euo pipefail

    VM_NAME="sealed-demo"

    # Clean up any previous VM with this name.  Also remove any stale custom
    # OVMF vars file; bcvk reuses it if present, which can leave old db keys
    # enrolled after regenerating signing keys.
    bcvk libvirt rm --stop --force "${VM_NAME}" 2>/dev/null || true
    rm -f "${HOME}/.local/share/libvirt/images/${VM_NAME}_OVMF_VARS.fd"

    echo "==> Booting sealed host VM..."
    bcvk libvirt run --detach --ssh-wait --name "${VM_NAME}" \
        --filesystem=ext4 \
        --secure-boot-keys "{{keys_dir}}" \
        "{{host_image}}"

    echo "==> Waiting for multi-user.target (timeout 120s)..."
    bcvk libvirt ssh "${VM_NAME}" -- \
        timeout 120 bash -c \
            'systemctl is-active multi-user.target || journalctl -b --no-pager -o cat UNIT=multi-user.target --follow | grep -q -m1 "Reached target"'

    echo "==> multi-user.target reached."

# Boot a VM and open an interactive SSH session.
bcvk-ssh: bcvk-boot
    #!/bin/bash
    set -euo pipefail
    VM_NAME="sealed-demo"
    bcvk libvirt ssh "${VM_NAME}"

# Boot a VM, verify composefs, and tear down.
bcvk-test: bcvk-boot
    #!/bin/bash
    set -euo pipefail

    VM_NAME="sealed-demo"
    trap 'echo "==> Cleaning up VM..."; bcvk libvirt rm --stop --force "${VM_NAME}"; echo "Done."' EXIT

    echo "==> Running checks..."
    bcvk libvirt ssh "${VM_NAME}" -- bash -c '
        set -euo pipefail

        echo "--- kernel ---"
        uname -r

        echo "--- root mount ---"
        mount | grep " / " || true
        if mount | grep -q "verity=require"; then
            echo "  OK: composefs root with verity=require"
        else
            echo "  FAIL: composefs root not detected"
            exit 1
        fi

        echo "--- cmdline ---"
        cat /proc/cmdline

        echo ""
        echo "=== COMPOSEFS BOOT VERIFIED ==="
    '

# Clean generated artifacts and VM
clean:
    #!/bin/bash
    set -euo pipefail
    bcvk libvirt rm --stop --force sealed-demo 2>/dev/null || true
    rm -rf target/
    podman rmi -f "{{host_image}}" "{{rootfs_image}}" 2>/dev/null || true
    echo "Cleaned"
